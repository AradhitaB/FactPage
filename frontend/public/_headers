# Cloudflare Pages edge headers — applied to every response served from this deployment.
# NOTE: Cloudflare Pages does not support environment variable injection into this file.
# connect-src must be updated manually if the backend URL changes, followed by a Cloudflare
# Pages redeploy. This file is not used during local Next.js development (next dev ignores it).
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=(), usb=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src 'self' https://abhandari.pythonanywhere.com; img-src 'self' data:; font-src 'self'; frame-ancestors 'none'; object-src 'none'; base-uri 'self'
