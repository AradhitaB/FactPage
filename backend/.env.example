# ─── Server ───────────────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | production
FRONTEND_URL=http://localhost:3000

# Local network testing (e.g. phone on same Wi-Fi) — comma-separated
# EXTRA_ORIGINS=http://192.168.1.154:3000

# ─── Statistical parameters ───────────────────────────────────────────────────
# Alpha: acceptable false positive rate (Type I error)
ALPHA=0.05

# Power: probability of detecting a real effect (1 - Type II error)
POWER=0.80

# MDE: minimum detectable effect — smallest absolute lift worth detecting
# e.g. 0.10 means we want to detect a change from 40% -> 50% conversion
MDE=0.10

# Baseline conversion rate assumption for power analysis
BASELINE_CONVERSION=0.50
