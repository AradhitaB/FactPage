# ─── Server ───────────────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | production
FRONTEND_URL=http://localhost:3000

# SQLite path — override in production to point to a persistent disk
# DB_PATH=/data/factpage.db

# Local network testing (e.g. phone on same Wi-Fi) — comma-separated
# EXTRA_ORIGINS=http://192.168.1.154:3000

# Set to true when deployed behind a reverse proxy that sets X-Forwarded-For
# with the real client IP (e.g. PythonAnywhere). Enables per-user rate limiting.
# Leave false (default) in local development.
# TRUST_PROXY_HEADERS=true

# ─── Statistical parameters ───────────────────────────────────────────────────
# Alpha: acceptable false positive rate per test (Type I error)
# Bonferroni-corrected for 2 simultaneous tests: 0.05 / 2 = 0.025
ALPHA=0.025

# Power: probability of detecting a real effect (1 - Type II error)
POWER=0.80

# MDE: minimum detectable effect — smallest absolute lift worth detecting
# e.g. 0.10 means we want to detect a change from 40% -> 50% conversion
MDE=0.10

# Baseline conversion rate assumption for power analysis
BASELINE_CONVERSION=0.50
